# Backend
DATABASE_URL=postgresql://user:password@localhost:5432/garment_erp
JWT_ACCESS_SECRET=your_access_secret_here
JWT_REFRESH_SECRET=your_refresh_secret_here
PORT=5000
NODE_ENV=production
BCRYPT_SALT_ROUNDS=12
ACCESS_TOKEN_TTL=900
REFRESH_TOKEN_TTL_ADMIN=28800
REFRESH_TOKEN_TTL_MOBILE=604800
REDIS_URL=redis://localhost:6379

# Bootstrap admin (run once on fresh DB)
ADMIN_BOOTSTRAP_EMP_ID=
ADMIN_BOOTSTRAP_NAME=
ADMIN_BOOTSTRAP_PASSWORD=
ADMIN_BOOTSTRAP_DESIGNATION=System Admin
ADMIN_BOOTSTRAP_ALLOW_RESET=false

# File Storage (optional)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# Frontend
# Local development
VITE_API_URL=http://localhost:5000/api
FRONTEND_ORIGIN=http://localhost:3000

# Production deployment
# Set this in Vercel after the backend is deployed on Render.
# Example: VITE_API_URL=https://garment-erp-backend.onrender.com/api
# Example: FRONTEND_ORIGIN=https://garment-erp-frontend.vercel.app
