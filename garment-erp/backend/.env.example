# Database
DATABASE_URL="postgresql://user:password@localhost:5432/garment_erp?schema=public"

# JWT Secrets
JWT_ACCESS_SECRET="your_access_token_secret_key_here_change_in_production"
JWT_REFRESH_SECRET="your_refresh_token_secret_key_here_change_in_production"

# Server
PORT=5000
NODE_ENV="development"

# Bcrypt
BCRYPT_SALT_ROUNDS=12

# Tokens TTL (in seconds)
ACCESS_TOKEN_TTL=900
REFRESH_TOKEN_TTL_ADMIN=28800
REFRESH_TOKEN_TTL_MOBILE=604800

# Cache
REDIS_URL="redis://localhost:6379"
